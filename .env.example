# Growth Atlas MVP - 开发环境变量模板
# 复制此文件为 .env 后填写本地开发值；不要提交包含真实密钥的 .env 文件。

# ==================== 应用环境 ====================

# 当前运行环境，用于切换开发、测试和生产配置。
APP_ENV=development

# FastAPI 服务显示名称。
APP_NAME=Growth Atlas API

# 是否启用调试模式；生产环境必须设为 false。
DEBUG=true

# 后端监听地址和端口。
API_HOST=0.0.0.0
API_PORT=8000

# API 路由统一前缀。
API_PREFIX=/api

# 日志级别，可选值通常为 DEBUG、INFO、WARNING、ERROR。
LOG_LEVEL=DEBUG

# ==================== React 前端 ====================

# 浏览器访问 FastAPI 的基础地址。
VITE_API_BASE_URL=http://localhost:8000/api

# Supabase 项目公开地址，可安全用于浏览器端身份认证。
VITE_SUPABASE_URL=

# Supabase 匿名公钥，仅用于浏览器端；不要在这里填写 service role 密钥。
VITE_SUPABASE_ANON_KEY=

# ==================== FastAPI 跨域配置 ====================

# 允许访问后端的前端来源，多个地址使用英文逗号分隔。
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ==================== Supabase / 数据库 ====================

# Supabase 项目地址，供 FastAPI 服务端访问。
SUPABASE_URL=

# Supabase 匿名公钥，供后端执行受用户身份和 RLS 约束的请求。
SUPABASE_ANON_KEY=

# Supabase service role 密钥，仅限 FastAPI 服务端使用，绝不可暴露给前端。
SUPABASE_SERVICE_ROLE_KEY=

# Supabase PostgreSQL 连接字符串，供迁移或需要直连数据库的服务端任务使用。
DATABASE_URL=

# ==================== OpenAI API ====================

# OpenAI API 密钥，仅限 FastAPI 服务端使用。
OPENAI_API_KEY=

# MVP 默认使用的 OpenAI 模型；可按项目实际选型修改。
OPENAI_MODEL=

# OpenAI API 请求超时时间（秒）。
OPENAI_TIMEOUT_SECONDS=60

# OpenAI API 单次请求的最大重试次数。
OPENAI_MAX_RETRIES=2

# ==================== 身份验证与安全 ====================

# Supabase JWT 签发方地址，用于 FastAPI 校验访问令牌。
SUPABASE_JWT_ISSUER=

# Supabase JWT 受众，开发阶段通常为 authenticated。
SUPABASE_JWT_AUDIENCE=authenticated

# ==================== 开发体验 ====================

# 时区，用于开发日志和后台任务的时间显示。
TZ=Asia/Shanghai
